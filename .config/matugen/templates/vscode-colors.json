{
  "material-code.colors": {
    "primary": "{{colors.primary.default.hex}}",
    "foreground": "{{colors.on_surface.default.hex}}",
    "mutedForeground": "{{colors.on_surface_variant.default.hex}}",
    "background": "{{colors.surface.default.hex}}",
    "card": "{{colors.surface_container.default.hex}}",
    "popover": "{{colors.surface_container_high.default.hex}}",
    "hover": "{{colors.surface_container_highest.default.hex}}",
    "border": "{{colors.outline_variant.default.hex}}",
    "primaryForeground": "{{colors.on_primary.default.hex}}",
    "secondary": "{{colors.secondary_container.default.hex}}",
    "secondaryForeground": "{{colors.on_secondary_container.default.hex}}",
    "error": "{{colors.error.default.hex}}",
    "errorForeground": "{{colors.on_error.default.hex}}",
    "syntax.comment": "{{colors.outline.default.hex}}",
    "syntax.keyword": "#e67e80",
    "syntax.string": "#dbbc7f",
    "syntax.variable": "{{colors.on_surface.default.hex}}",
    "syntax.function": "#e67e80",
    "syntax.property": "{{colors.on_surface.default.hex}}",
    "syntax.constant": "#7fbbb3",
    "syntax.attribute": "#dbbc7f",
    "syntax.bracket1": "#e67e80",
    "syntax.bracket2": "#dbbc7f",
    "syntax.bracket3": "#a7c080",
    "syntax.bracket4": "#83c092"
  },
  "workbench.colorCustomizations": {
    "editorError.foreground": "#e67e80",
    "gitDecoration.modifiedResourceForeground": "#7fbbb3",
    "gitDecoration.untrackedResourceForeground": "#dbbc7f",
    "editorInlayHint.background": "#00000000",
    "background": "{{colors.surface.default.hex}}",
    "terminal.background": "{{colors.surface.default.hex}}",
    "terminal.foreground": "{{colors.on_surface.default.hex}}",
    "terminal.border": "{{colors.outline_variant.default.hex}}",
    "panel.background": "{{colors.surface.default.hex}}",
    "panel.border": "{{colors.outline_variant.default.hex}}",
    "panelTitle.activeForeground": "{{colors.primary.default.hex}}",
    "panelTitle.inactiveForeground": "{{colors.on_surface_variant.default.hex}}",
    "panelTitle.activeBorder": "{{colors.primary.default.hex}}",
    "terminal.ansiBlack":   "{{colors.surface.default.hex}}",
    "terminal.ansiRed":     "{{colors.error.default.hex}}",
    "terminal.ansiGreen":   "{{colors.primary.default.hex}}",
    "terminal.ansiYellow":  "{{colors.tertiary.default.hex}}",
    "terminal.ansiBlue":    "{{colors.on_primary_container.default.hex}}",
    "terminal.ansiMagenta": "{{colors.on_secondary_container.default.hex}}",
    "terminal.ansiCyan":    "{{colors.secondary.default.hex}}",
    "terminal.ansiWhite":   "{{colors.on_surface.default.hex}}"
  },
  "editor.semanticTokenColorCustomizations": {
    "enabled": true,
    "rules": {
      "function": "#a7c080",
      "method": "#a7c080",
      "formatSpecifier": "#a7c080",
      "namespace": "#d699b6",
      "selfKeyword": "#d699b6"
    }
  },
  "editor.tokenColorCustomizations": {
    "textMateRules": [
      {
        "scope": "punctuation",
        "settings": {
          "foreground": "{{colors.on_surface.default.hex}}"
        }
      },
      {
        "scope": "storage.modifier",
        "settings": {
          "foreground": "#e69875"
        }
      },
      {
        "scope": "storage.type, punctuation.definition",
        "settings": {
          "foreground": "#7fbbb3"
        }
      },
      {
        "scope": "storage.modifier.import.java, storage.modifier.package.java, constant, constant.other",
        "settings": {
          "foreground": "#d699b6"
        }
      }
    ]
  }
}
